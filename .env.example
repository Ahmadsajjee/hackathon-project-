# .env.example - Template for environment configuration
# Copy this to .env and fill in your actual values

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
ASSISTANT_ID=asst_your_assistant_id_here

# Flask Configuration (optional)
FLASK_DEBUG=True
FLASK_ENV=development

# Setup Instructions:
# 1. Create an Azure OpenAI resource in Azure Portal
# 2. Deploy a GPT-4 model (e.g., gpt-4o)
# 3. Go to Azure AI Studio → Create Assistant
# 4. Enable File Search tool on your assistant
# 5. Create a Vector Store and upload your healthcare_faq.md file
# 6. Attach the Vector Store to your assistant
# 7. Copy your Assistant ID from Azure AI Studio
# 8. Go to Azure Portal → Your OpenAI resource → Keys and Endpoint
# 9. Copy API Key and Endpoint URL
# 10. Replace the placeholder values above with your actual credentials